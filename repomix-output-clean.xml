        ...

class Tool(ABC):
    """Clase base para herramientas del agente."""
    name: str
    description: str
    enabled: bool = True

    @abstractmethod
    async def execute(self, args: Dict[str, Any], workspace: Optional[str] = None) -> str:
        """Ejecuta la herramienta con los argumentos dados."""
