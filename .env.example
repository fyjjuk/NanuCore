# ============================================================
# NanuCore 3.0 - Configuración de Variables de Entorno
# ============================================================
# Instrucciones:
# 1. Copia este archivo a .env
# 2. Rellena tus claves API donde sea necesario
# 3. Las claves marcadas como (opcional) pueden dejarse en blanco
# 4. Los servicios no configurados se omitirán automáticamente
# ============================================================

# ---------- SERVIDORES LLM LOCALES ----------
# Ollama - Servidor local de modelos (recomendado para desarrollo)
# Instalación: https://ollama.ai/
# Modelos populares: phi3:mini, llama3.2:3b, qwen2.5:0.5b
# Puerto por defecto: 11434
OLLAMA_HOST=http://localhost:11434

# ---------- SERVIDORES LLM EN LA NUBE (GRATUITOS) ----------
# Todos los siguientes proveedores ofrecen capas gratuitas con límites diarios
# El router intentará cada proveedor en orden hasta encontrar uno disponible

# Google Gemini - Modelos: gemini-1.5-flash, gemini-1.5-pro
# Obtén clave: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Groq - Inferencia ultrarrápida
# Modelos: llama-3.3-70b-versatile, llama3-8b-8192, mixtral-8x7b-32768
# Obtén clave: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter - Agregador de modelos (acceso a 25+ modelos)
# Modelo recomendado: meta-llama/llama-3.3-70b-instruct
# Obtén clave: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Cerebras - Modelo Llama3.3 70B gratuito
# Modelo: llama3.3-70b
# Obtén clave: https://cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_key_here

# Mistral AI - Modelos europeos de alto rendimiento
# Modelos: mistral-small-latest, mistral-medium-latest
# Obtén clave: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_key_here

# ---------- SEGURIDAD ----------
# Passphrase para cifrar credenciales sensibles (AES-256-GCM)
# Si no se establece, el cifrado no estará disponible
# Genera una frase segura: openssl rand -base64 32
NANU_CREDENTIAL_PASSPHRASE=your_secure_passphrase_here

# Salt para el cifrado (opcional - se genera automáticamente)
# NANU_CREDENTIAL_SALT=your_base64_salt_here

# ---------- LOGGING ----------
# Niveles: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------- ASISTENTE DE VOZ (Linux/ALSA) ----------
# Habilita el canal de voz (requiere arecord, mpg123, edge-tts)
# Solo funciona en Linux con ALSA
FERDONAN_VOICE_ENABLED=false

# ---------- GATEKEEPER (aprobación humana) ----------
# Tiempo máximo para esperar aprobación humana (segundos)
GATEKEEPER_TIMEOUT=60

# Si es true, pide aprobación para TODAS las rutas (ignora gatekeeper_required)
GATEKEEPER_FORCE_ALL=false

# ---------- RUTAS DE DATOS (personalización avanzada) ----------
# Directorio base para datos persistentes (memoria, caché, vectores)
# NANU_DATA_DIR=nanu/data

# Directorio de caché (por defecto: NANU_DATA_DIR/cache)
# NANU_CACHE_DIR=nanu/data/cache

# Directorio de modelos (ej. Vosk para STT)
# NANU_MODELS_DIR=models

# ---------- SELECCIÓN DE MODELOS (avanzado) ----------
# Modo de selección: auto | manual | weighted
# auto: elige el primer proveedor disponible
# manual: permite seleccionar manualmente desde CLI
# weighted: selecciona según prioridad y disponibilidad
# MODEL_SELECTION_MODE=auto

# ============================================================
# NOTAS IMPORTANTES:
# ============================================================
# 1. Las claves API son sensibles - NO las compartas
# 2. Los proveedores gratuitos tienen límites diarios (~50-100 requests/día)
# 3. El router rota automáticamente entre proveedores si uno falla
# 4. Ollama es el único proveedor local (sin límites de API)
# 5. Para usar el agente Spotify, necesitas playerctl instalado:
#    sudo pacman -S playerctl  # Arch Linux
#    sudo apt install playerctl  # Debian/Ubuntu
# 6. Para el asistente de voz (Linux):
#    sudo pacman -S alsa-utils mpg123  # Arch Linux
#    sudo apt install alsa-utils mpg123  # Debian/Ubuntu
# ============================================================
