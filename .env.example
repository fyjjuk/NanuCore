# NanuCore 3.0 – Variables de entorno
# Copia este archivo a .env y edítalo con tus configuraciones

# ---------- LLM Providers ----------
# Ollama (local)
OLLAMA_HOST=http://localhost:11434

# Google Gemini (opcional - soporta múltiples keys: GOOGLE_API_KEY_1, GOOGLE_API_KEY_2, ...)
GOOGLE_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY_1=your_second_key_here

# Groq (opcional - soporta múltiples keys: GROQ_API_KEY_1, GROQ_API_KEY_2, ...)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_API_KEY_1=your_second_key_here

# ---------- Security (Credential Manager) ----------
# Passphrase para cifrar credenciales (AES-256-GCM)
# Si no se establece, el cifrado no estará disponible
NANU_CREDENTIAL_PASSPHRASE=your_secure_passphrase_here
# Salt opcional (se genera automáticamente si no se proporciona)
# NANU_CREDENTIAL_SALT=your_base64_salt_here

# ---------- Logging ----------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ---------- Voice Assistant (Linux/ALSA) ----------
# Habilita el canal de voz (requiere arecord, mpg123 y edge-tts)
FERDONAN_VOICE_ENABLED=false

# ---------- Gatekeeper (aprobación humana) ----------
GATEKEEPER_TIMEOUT=60   # Segundos para esperar aprobación
GATEKEEPER_FORCE_ALL=false  # Si es true, pide aprobación para TODAS las rutas

# ---------- Rutas de datos (opcional) ----------
# NANU_DATA_DIR=nanu/data   # Directorio base para datos persistentes
# NANU_CACHE_DIR=nanu/data/cache   # Directorio de caché
# NANU_MODELS_DIR=models   # Directorio para modelos (ej. Vosk)
